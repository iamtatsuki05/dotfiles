{
  "cleanupPeriodDays": 36500,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Glob",
      "Grep",
      "LS"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets.env)",
      "Read(*.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.env)",
      "Read(config/shell/secrets.env)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(*_rsa)",
      "Read(*_ecdsa)",
      "Read(*_ed25519)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(.aws/credentials)",
      "Read(.ssh/id_*)",
      "Read(.npmrc)",
      "Read(.pypirc)",
      "Read(config.json)",
      "Read(secrets.json)",
      "Read(**/credentials*)",
      "Read(**/secret*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets.env)",
      "Edit(config/shell/secrets.env)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets.json)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "MultiEdit(**/.env)",
      "MultiEdit(**/.env.*)",
      "MultiEdit(**/secrets.env)",
      "MultiEdit(config/shell/secrets.env)",
      "MultiEdit(**/credentials.json)",
      "MultiEdit(**/secrets.json)",
      "MultiEdit(**/*.key)",
      "MultiEdit(**/*.pem)",
      "MultiEdit(**/id_rsa)",
      "MultiEdit(**/id_ed25519)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets.env)",
      "Write(config/shell/secrets.env)",
      "Write(**/credentials.json)",
      "Write(**/secrets.json)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Bash(mount:*)",
      "Bash(umount:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_context_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_context_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_context_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_context_reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_turn_done_notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jupytext_sync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent_turn_done_notify.sh",
            "timeout": 5
          },
          {
            "type": "prompt",
            "prompt": "あなたは Agent system の停止判定レビュー担当です。メインの Agent が停止してよい状態かを判定してください。Hook 入力: $ARGUMENTS\n\nJSON だけを返してください: {\"ok\": true} または {\"ok\": false, \"reason\": \"...\"}。\n\n原則として停止を許可してください。純粋な説明、計画回答、ユーザーへの質問、指摘ありのレビュー、またはユーザーが編集・作成・操作を依頼していないケースはブロックしないでください。\n\nブロックするのは、最後の応答がコード、設定、文書、資料、データ、ブラウザ操作などの作業完了を明確に主張しているのに検証状況と残リスクの両方を欠いている場合、または必須作業が残っていると書きながら停止しようとしている場合だけです。無限ループを避けるため、stop_hook_active が true の場合は重大な未解決安全問題がない限り許可してください。\n\nブロックする場合、reason は最終回答前に Agent が行うべきことを示す短い日本語の実行指示にしてください。例: git diff を確認する、関連テストを実行する、必要なら .agent/work/sessions に記録する、未検証事項を報告する。",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true
  },
  "effortLevel": "xhigh",
  "autoCompactEnabled": false,
  "co_authored_commits": true,
  "BASH_DEFAULT_TIMEOUT_MS": 600000,
  "BASH_MAX_TIMEOUT_MS": 600000,
  "MCP_TOOL_TIMEOUT": 600000,
  "DISABLE_AUTOUPDATER": "0",
  "ANTHROPIC_MODEL": "claude-sonnet-4-6",
  "MAX_THINKING_TOKENS": 32000
}
