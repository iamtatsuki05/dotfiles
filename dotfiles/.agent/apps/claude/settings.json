{
  "cleanupPeriodDays": 36500,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Read",
      "Edit",
      "MultiEdit",
      "Write",
      "Glob",
      "Grep",
      "LS"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets.env)",
      "Read(*.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.env)",
      "Read(config/shell/secrets.env)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(*.key)",
      "Read(*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(*_rsa)",
      "Read(*_ecdsa)",
      "Read(*_ed25519)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(.aws/credentials)",
      "Read(.ssh/id_*)",
      "Read(.npmrc)",
      "Read(.pypirc)",
      "Read(config.json)",
      "Read(secrets.json)",
      "Read(**/credentials*)",
      "Read(**/secret*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets.env)",
      "Edit(config/shell/secrets.env)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets.json)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "MultiEdit(**/.env)",
      "MultiEdit(**/.env.*)",
      "MultiEdit(**/secrets.env)",
      "MultiEdit(config/shell/secrets.env)",
      "MultiEdit(**/credentials.json)",
      "MultiEdit(**/secrets.json)",
      "MultiEdit(**/*.key)",
      "MultiEdit(**/*.pem)",
      "MultiEdit(**/id_rsa)",
      "MultiEdit(**/id_ed25519)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets.env)",
      "Write(config/shell/secrets.env)",
      "Write(**/credentials.json)",
      "Write(**/secrets.json)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Bash(mount:*)",
      "Bash(umount:*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/jupytext_sync.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true
  },
  "effortLevel": "xhigh",
  "co_authored_commits": true,
  "BASH_DEFAULT_TIMEOUT_MS": 600000,
  "BASH_MAX_TIMEOUT_MS": 600000,
  "MCP_TOOL_TIMEOUT": 600000,
  "DISABLE_AUTOUPDATER": "0",
  "ANTHROPIC_MODEL": "claude-sonnet-4-6",
  "MAX_THINKING_TOKENS": 32000,
  "autoCompactEnabled": false
}
