{
  "agent": {
    "model": "adaptive",
    "show_history_on_continue": true
  },
  "auto_update": false,
  "notify": "smart",
  "show_path": true,
  "unicode_mode": "auto",
  "include_gitignored_files": false,
  "respect_gitignore": true,
  "permissions": {
    "allow": [
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_press_key"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.env)",
      "Read(config/shell/secrets.env)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets.env)",
      "Write(config/shell/secrets.env)",
      "Write(**/credentials.json)",
      "Write(**/secrets.json)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)"
    ],
    "ask": []
  },
  "mcpServers": {
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "transport": "http"
    },
    "devin": {
      "url": "https://mcp.devin.ai/mcp",
      "transport": "http",
      "headers": {
        "Authorization": "Bearer ${DEVIN_API_KEY}"
      }
    },
    "gemini-cli": {
      "command": "bunx",
      "args": [
        "mcp-gemini-cli",
        "--allow-npx"
      ],
      "env": {}
    },
    "colab-mcp": {
      "command": "uvx",
      "args": [
        "git+https://github.com/googlecolab/colab-mcp"
      ],
      "env": {}
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "transport": "http"
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "env": {}
    }
  },
  "read_config_from": {
    "claude": true,
    "cursor": true,
    "windsurf": true,
    "opencode": true,
    "vscode": true,
    "zed": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/devin/hooks/jupytext_sync.sh"
          }
        ]
      }
    ]
  }
}
