{
  "autoUpdate": false,
  "disableAllHooks": false,
  "effortLevel": "xhigh",
  "experimental": true,
  "model": "auto",
  "respectGitignore": true,
  "allowedUrls": [
    "github.com",
    "*.github.com",
    "docs.github.com",
    "api.github.com",
    "*.githubusercontent.com",
    "mcp.deepwiki.com",
    "mcp.devin.ai",
    "mcp.notion.com"
  ],
  "deniedUrls": [],
  "footer": {
    "showAgent": true,
    "showBranch": true,
    "showContextWindow": true,
    "showDirectory": true,
    "showModelEffort": true,
    "showQuota": true
  },
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "zsh \"$HOME/.copilot/hooks/agent_context_reminder.sh\"",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "zsh \"$HOME/.copilot/hooks/agent_context_reminder.sh\"",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "zsh \"$HOME/.copilot/hooks/jupytext_sync.sh\"",
        "timeoutSec": 30
      }
    ]
  }
}
