model = "gpt-5.4"
model_reasoning_effort = "xhigh"
hide_agent_reasoning = true
network_access = true
web_search = "live"
disable_response_storage = true
# for http header
rmcp_client = true
notify = ["bash", "-lc", "afplay /System/Library/Sounds/Ping.aiff"]
personality = "pragmatic"

[mcp_servers.deepwiki]
command = "bunx"
args = ["mcp-remote", "https://mcp.deepwiki.com/mcp"]
startup_timeout_sec = 60

[mcp_servers.devin]
url = "https://mcp.devin.ai/mcp"
bearer_token_env_var = "DEVIN_API_KEY"
startup_timeout_sec = 60

[mcp_servers.gemini-cli]
command = "bunx"
args = ["mcp-gemini-cli", "--allow-npx"]

[mcp_servers.notion]
command = "bunx"
args = ["mcp-remote", "https://mcp.notion.com/mcp"]
startup_timeout_sec = 60

[mcp_servers.playwright]
command = "bunx"
args = ["@playwright/mcp@latest"]

[mcp_servers.playwright.tools.browser_resize]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_evaluate]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_run_code]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_navigate]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_tabs]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_fill_form]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_click]
approval_mode = "approve"

[mcp_servers.playwright.tools.browser_press_key]
approval_mode = "approve"

[plugins."gmail@openai-curated"]
enabled = true

[plugins."github@openai-curated"]
enabled = true
