# Shell environment variables for local secrets.
# Copy is created automatically at ~/.config/shell/secrets.env on setup.
# Fill in only the values you need, then restart the shell or run:
#   source ~/.config/shell/secrets.env

export OPENAI_API_KEY=""
export ANTHROPIC_API_KEY=""
export GEMINI_API_KEY=""

export SLACK_WEBHOOK_URL=""

# Devin MCP API key (used by Claude Code / Gemini CLI / Codex CLI)
# export DEVIN_BEARER_TOKEN="Bearer apk_user_..."
